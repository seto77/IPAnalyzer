<?xml version="1.0" encoding="utf-8"?>
<!-- 260625Cl 追加: vdproj (IPAnalyzerSetup.vdproj) の WiX v7 等価再現。PDIndexer\PDIndexerSetup.Wix\Package.wxs を IPAnalyzer 用に移植。
     不可侵: UpgradeCode / per-user (LocalAppData) / framework-dependent / 出力名 IPAnalyzer-setup.msi (x64)
     IPAnalyzer 固有: native 依存ゼロ (libxrl/Crystallography.Native を同梱しない)。glfw3.dll は OpenTK 透過の死荷物として staging 後処理で除外。 -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="IPAnalyzer" Manufacturer="Crystallography Software"
           Version="$(var.ProductVersion)"
           UpgradeCode="7C0F1D74-5E13-4143-826B-A422F43A7514"
           Scope="perUser" Language="1033" Compressed="yes">

    <SummaryInformation Description="IPAnalyzerSetup" />

    <!-- AllowSameVersionUpgrades: x64⇔arm64 の same-version cross-grade (同一 UpgradeCode・別 ProductCode) を許可。
         IgnoreLanguage: 旧 vdproj MSI は ProductLanguage=0 (neutral, LanguageId=0) のため言語不問で検出。
         旧 vdproj (DetectNewerInstalledVersion=FALSE) と異なりダウングレードはブロックする (仕様改善)。 -->
    <MajorUpgrade AllowSameVersionUpgrades="yes" IgnoreLanguage="yes"
                  Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <!-- CompressionLevel high (PDIndexer/ReciPro 実績: 既定 mszip より小さくなる) -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="AppIcon.ico" SourceFile="..\IPAnalyzer\App.ico" />

    <!-- per-user 固定: %LocalAppData%\Crystallography Software\IPAnalyzer (vdproj の DefaultLocation を踏襲) -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ManufacturerFolder" Name="Crystallography Software">
        <Directory Id="INSTALLFOLDER" Name="IPAnalyzer">
          <!-- exe のみ明示 File (ショートカット/Launch CA の参照 Id を固定するため) -->
          <Component Id="MainExe">
            <File Id="IPAnalyzerExe" Source="!(bindpath.staging)\IPAnalyzer.exe" KeyPath="yes" />
          </Component>
          <!-- 残り全部をワイルドカード収集 (staging の内容が正。exe は重複登録になるため除外) -->
          <Files Include="!(bindpath.staging)\**">
            <Exclude Files="!(bindpath.staging)\IPAnalyzer.exe" />
          </Files>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- ショートカット: デスクトップ + スタートメニュー (vdproj と同一の2箇所、icon は App.ico) -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComp">
        <Shortcut Id="DesktopShortcut" Name="IPAnalyzer" Target="[#IPAnalyzerExe]"
                  WorkingDirectory="INSTALLFOLDER" Icon="AppIcon.ico" />
        <RegistryValue Root="HKCU" Key="Software\Crystallography Software\IPAnalyzer"
                       Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="VendorMenuFolder" Name="Crystallography Software">
        <Component Id="StartMenuShortcutComp">
          <Shortcut Id="StartMenuShortcut" Name="IPAnalyzer" Target="[#IPAnalyzerExe]"
                    WorkingDirectory="INSTALLFOLDER" Icon="AppIcon.ico" />
          <RemoveFolder Id="RemoveVendorMenuFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\Crystallography Software\IPAnalyzer"
                         Name="startmenu" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- UI: WixUI_InstallDir (Everyone/Just me ラジオは廃止し per-user 固定)。
         REQUIREMENT.rtf は専用ダイアログを設けずファイル同梱のみ (staging 経由)。 -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <!-- 260625Cl LICENSE.rtf / REQUIREMENT.rtf は本フォルダ (IPAnalyzerSetup.Wix\) に配置し WiX プロジェクトを自己完結化
         (旧 vdproj フォルダ IPAnalyzerSetup\ への参照依存を排除。PDIndexer の最終形と同一)。旧 vdproj 一式は WiX 版リリースが
         1 回成功するまでロールバック用に残し、成功後に IPAnalyzerSetup\ ごと削除する。WixUILicenseRtf は wixproj 基準の相対パス。 -->
    <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />

    <!-- 完了画面「Launch IPAnalyzer」既定 ON (旧 EnableLaunchApplication.js が MSI に注入していた CA の等価再現) -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch IPAnalyzer" />
    <Property Id="WixShellExecTarget" Value="[#IPAnalyzerExe]" />
    <CustomAction Id="LaunchApp" DllEntry="WixShellExec" Impersonate="yes"
                  Execute="immediate" Return="check"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)" />
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApp"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>

  </Package>
</Wix>
